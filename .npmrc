# Run the studio package's postinstall (the @ffmpeg/core-mt patch) after install.
enable-pre-post-scripts=true
# Copy packages into node_modules instead of hardlinking from the global store, so
# the postinstall patch that edits node_modules/@ffmpeg/core-mt can't corrupt the
# shared store (it would, via the hardlink, otherwise). `pnpm patch` is unusable
# here — its binary diff corrupts the 32 MB wasm core.
package-import-method=copy
