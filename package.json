{
  "name": "bffless-apps",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "studio:dev": "pnpm --filter studio dev",
    "studio:build": "pnpm --filter studio build",
    "studio:lint": "pnpm --filter studio lint",
    "studio:test": "pnpm --filter studio test:run",
    "handoff:dev": "pnpm --filter handoff dev",
    "handoff:build": "pnpm --filter handoff build",
    "handoff:lint": "pnpm --filter handoff lint",
    "handoff:test": "pnpm --filter handoff test:run",
    "skills:sync": "node scripts/sync-skills.mjs",
    "skills:check": "node scripts/sync-skills.mjs --check",
    "sandcastle": "npx tsx .sandcastle/main.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@tailwindcss/oxide"
    ]
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.10.0",
    "@playwright/test": "1.61.1"
  }
}
